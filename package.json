{
  "name": "bugpin",
  "version": "1.0.6",
  "description": "Self-hosted visual bug reporting tool",
  "license": "AGPL-3.0-only",
  "private": false,
  "type": "module",
  "workspaces": [
    "src/server",
    "src/admin",
    "src/widget"
  ],
  "scripts": {
    "dev": "bun run dev:server & bun run dev:admin",
    "dev:server": "bun run --cwd src/server dev",
    "dev:admin": "bun run --cwd src/admin dev",
    "dev:widget": "bun run --cwd src/widget build:watch",
    "build": "bun run build:server && bun run build:admin && bun run build:widget",
    "build:server": "bun run --cwd src/server build",
    "build:admin": "bun run --cwd src/admin build",
    "build:widget": "bun run --cwd src/widget build",
    "start": "bun run src/server/index.ts",
    "typecheck": "bun run typecheck:server && bun run typecheck:admin && bun run typecheck:widget",
    "typecheck:server": "bun run --cwd src/server typecheck",
    "typecheck:admin": "bun run --cwd src/admin typecheck",
    "typecheck:widget": "bun run --cwd src/widget typecheck",
    "test": "bun run test:server && bun run test:admin && bun run test:widget",
    "test:server": "bun test tests/server",
    "test:admin": "bun run --cwd src/admin test",
    "test:widget": "bun run --cwd src/widget test",
    "migrate": "bun run --cwd src/server migrate",
    "knip": "knip",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "knip": "^5.88.1",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "fast-xml-parser": "^5.7.2",
    "tar": "^7.5.13",
    "dompurify": "^3.4.2",
    "smol-toml": "^1.6.1",
    "brace-expansion": "^2.0.3",
    "follow-redirects": "^1.16.0",
    "markdown-it": "^14.1.1",
    "postcss": "^8.5.13",
    "rollup": "^4.60.2",
    "minimatch": "^9.0.9",
    "picomatch": "^4.0.4"
  }
}
