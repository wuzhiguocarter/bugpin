{
  "name": "@bugpin/server",
  "version": "1.0.15",
  "license": "AGPL-3.0-only",
  "description": "BugPin server - Bun + Hono backend",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "dev": "NODE_ENV=development bun --watch index.ts",
    "build": "bun build index.ts --outdir ../../dist/server --target bun",
    "start": "bun run index.ts",
    "typecheck": "tsc --noEmit",
    "migrate": "bun run storage/migrations/index.ts",
    "migrate-to-s3": "bun run scripts/migrate-to-s3.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1040.0",
    "hono": "^4.12.16",
    "nodemailer": "^8.0.7",
    "sharp": "^0.34.5",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/nodemailer": "^7.0.11",
    "bun-types": "^1.3.13",
    "typescript": "^5.9.3"
  }
}
