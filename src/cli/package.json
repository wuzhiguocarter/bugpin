{
  "name": "@bugpin/cli",
  "version": "1.0.14",
  "license": "AGPL-3.0-only",
  "description": "BugPin admin CLI - operate the admin REST API from the terminal",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "bugpin-cli": "src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ../../dist/cli --target bun",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "commander": "^12.1.0",
    "prompts": "^2.4.2",
    "tough-cookie": "^5.0.0"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "bun-types": "^1.3.13",
    "typescript": "^5.9.3"
  }
}
